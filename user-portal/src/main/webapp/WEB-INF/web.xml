<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="https://jakarta.ee/xml/ns/jakartaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd"
         version="6.0">
  <display-name>Easy2WorkSite</display-name>

  <!-- Optional admin key if E2W_ADMIN_KEY env is not set. When MySQL is on, leave empty and use env only. -->
  <context-param>
    <param-name>easy2workAdminKey</param-name>
    <param-value></param-value>
  </context-param>

  <context-param>
    <param-name>jdbcUrl</param-name>
    <param-value></param-value>
  </context-param>
  <context-param>
    <param-name>jdbcUser</param-name>
    <param-value></param-value>
  </context-param>
  <context-param>
    <param-name>jdbcPassword</param-name>
    <param-value></param-value>
  </context-param>

  <listener>
    <listener-class>com.easy2work.backend.config.DatabaseConfig</listener-class>
  </listener>

  <filter>
    <filter-name>ApiCorsFilter</filter-name>
    <filter-class>com.easy2work.backend.api.ApiCorsFilter</filter-class>
  </filter>
  <filter-mapping>
    <filter-name>ApiCorsFilter</filter-name>
    <url-pattern>/api/*</url-pattern>
  </filter-mapping>

  <filter>
    <filter-name>UserAuthFilter</filter-name>
    <filter-class>com.easy2work.web.filter.UserAuthFilter</filter-class>
  </filter>
  <filter-mapping>
    <filter-name>UserAuthFilter</filter-name>
    <url-pattern>/booking</url-pattern>
  </filter-mapping>
  <filter-mapping>
    <filter-name>UserAuthFilter</filter-name>
    <url-pattern>/my-bookings</url-pattern>
  </filter-mapping>

  <servlet>
    <servlet-name>ApiDiscoveryServlet</servlet-name>
    <servlet-class>com.easy2work.backend.api.ApiDiscoveryServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>ApiDiscoveryServlet</servlet-name>
    <url-pattern>/api/discovery</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>StatsApiServlet</servlet-name>
    <servlet-class>com.easy2work.backend.api.StatsApiServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>StatsApiServlet</servlet-name>
    <url-pattern>/api/stats</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>HealthApiServlet</servlet-name>
    <servlet-class>com.easy2work.backend.api.HealthApiServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>HealthApiServlet</servlet-name>
    <url-pattern>/api/health</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>ServicesApiServlet</servlet-name>
    <servlet-class>com.easy2work.backend.api.ServicesApiServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>ServicesApiServlet</servlet-name>
    <url-pattern>/api/services</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>ServiceDetailApiServlet</servlet-name>
    <servlet-class>com.easy2work.backend.api.ServiceDetailApiServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>ServiceDetailApiServlet</servlet-name>
    <url-pattern>/api/service-detail</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>BookingsApiServlet</servlet-name>
    <servlet-class>com.easy2work.backend.api.BookingsApiServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>BookingsApiServlet</servlet-name>
    <url-pattern>/api/bookings</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>BookingApiServlet</servlet-name>
    <servlet-class>com.easy2work.backend.api.BookingApiServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>BookingApiServlet</servlet-name>
    <url-pattern>/api/booking</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>ReviewsApiServlet</servlet-name>
    <servlet-class>com.easy2work.backend.api.ReviewsApiServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>ReviewsApiServlet</servlet-name>
    <url-pattern>/api/reviews</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>UserLoginServlet</servlet-name>
    <servlet-class>com.easy2work.web.servlet.UserLoginServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>UserLoginServlet</servlet-name>
    <url-pattern>/login</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>UserRegisterServlet</servlet-name>
    <servlet-class>com.easy2work.web.servlet.UserRegisterServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>UserRegisterServlet</servlet-name>
    <url-pattern>/register</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>LogoutServlet</servlet-name>
    <servlet-class>com.easy2work.web.servlet.LogoutServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>LogoutServlet</servlet-name>
    <url-pattern>/logout</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>BookingServlet</servlet-name>
    <servlet-class>com.easy2work.web.servlet.BookingServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>BookingServlet</servlet-name>
    <url-pattern>/booking</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>MyBookingsServlet</servlet-name>
    <servlet-class>com.easy2work.web.servlet.MyBookingsServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>MyBookingsServlet</servlet-name>
    <url-pattern>/my-bookings</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>ServiceDetailServlet</servlet-name>
    <servlet-class>com.easy2work.web.servlet.ServiceDetailServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>ServiceDetailServlet</servlet-name>
    <url-pattern>/service</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>AdminServlet</servlet-name>
    <servlet-class>com.easy2work.web.servlet.AdminServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>AdminServlet</servlet-name>
    <url-pattern>/admin/bookings</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>AdminServlet</servlet-name>
    <url-pattern>/admin-bookings</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>AdminUpdateStatusServlet</servlet-name>
    <servlet-class>com.easy2work.web.servlet.AdminUpdateStatusServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>AdminUpdateStatusServlet</servlet-name>
    <url-pattern>/admin/update-status</url-pattern>
  </servlet-mapping>

  <welcome-file-list>
    <welcome-file>index.jsp</welcome-file>
  </welcome-file-list>
</web-app>
