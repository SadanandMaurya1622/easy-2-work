<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="https://jakarta.ee/xml/ns/jakartaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd"
         version="6.0">
  <display-name>Easy2Work Admin Portal</display-name>

  <!-- Admin key configuration - set via environment variable E2W_ADMIN_KEY -->
  <context-param>
    <param-name>easy2workAdminKey</param-name>
    <param-value></param-value>
  </context-param>

  <!-- Database configuration -->
  <context-param>
    <param-name>jdbcUrl</param-name>
    <param-value></param-value>
  </context-param>
  <context-param>
    <param-name>jdbcUser</param-name>
    <param-value></param-value>
  </context-param>
  <context-param>
    <param-name>jdbcPassword</param-name>
    <param-value></param-value>
  </context-param>

  <!-- Database configuration listener -->
  <listener>
    <listener-class>com.easy2work.backend.config.DatabaseConfig</listener-class>
  </listener>

  <!-- Admin Authentication Filter -->
  <filter>
    <filter-name>AdminAuthFilter</filter-name>
    <filter-class>com.easy2work.web.filter.AdminAuthFilter</filter-class>
  </filter>
  <filter-mapping>
    <filter-name>AdminAuthFilter</filter-name>
    <url-pattern>/bookings</url-pattern>
  </filter-mapping>
  <filter-mapping>
    <filter-name>AdminAuthFilter</filter-name>
    <url-pattern>/update-status</url-pattern>
  </filter-mapping>
  <filter-mapping>
    <filter-name>AdminAuthFilter</filter-name>
    <url-pattern>/services</url-pattern>
  </filter-mapping>
  <filter-mapping>
    <filter-name>AdminAuthFilter</filter-name>
    <url-pattern>/users</url-pattern>
  </filter-mapping>
  <filter-mapping>
    <filter-name>AdminAuthFilter</filter-name>
    <url-pattern>/reviews</url-pattern>
  </filter-mapping>
  <filter-mapping>
    <filter-name>AdminAuthFilter</filter-name>
    <url-pattern>/reports</url-pattern>
  </filter-mapping>
  <filter-mapping>
    <filter-name>AdminAuthFilter</filter-name>
    <url-pattern>/settings</url-pattern>
  </filter-mapping>
  <filter-mapping>
    <filter-name>AdminAuthFilter</filter-name>
    <url-pattern>/api/admin/*</url-pattern>
  </filter-mapping>

  <!-- Admin Login Servlet -->
  <servlet>
    <servlet-name>AdminLoginServlet</servlet-name>
    <servlet-class>com.easy2work.web.servlet.AdminLoginServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>AdminLoginServlet</servlet-name>
    <url-pattern>/login</url-pattern>
  </servlet-mapping>

  <!-- Admin Logout Servlet -->
  <servlet>
    <servlet-name>AdminLogoutServlet</servlet-name>
    <servlet-class>com.easy2work.web.servlet.AdminLogoutServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>AdminLogoutServlet</servlet-name>
    <url-pattern>/logout</url-pattern>
  </servlet-mapping>

  <!-- Admin Bookings Servlet -->
  <servlet>
    <servlet-name>AdminServlet</servlet-name>
    <servlet-class>com.easy2work.web.servlet.AdminServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>AdminServlet</servlet-name>
    <url-pattern>/bookings</url-pattern>
  </servlet-mapping>

  <!-- Admin Update Status Servlet -->
  <servlet>
    <servlet-name>AdminUpdateStatusServlet</servlet-name>
    <servlet-class>com.easy2work.web.servlet.AdminUpdateStatusServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>AdminUpdateStatusServlet</servlet-name>
    <url-pattern>/update-status</url-pattern>
  </servlet-mapping>

  <!-- Admin Services Servlet -->
  <servlet>
    <servlet-name>AdminServicesServlet</servlet-name>
    <servlet-class>com.easy2work.web.servlet.AdminServicesServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>AdminServicesServlet</servlet-name>
    <url-pattern>/services</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>AdminUsersServlet</servlet-name>
    <servlet-class>com.easy2work.web.servlet.AdminUsersServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>AdminUsersServlet</servlet-name>
    <url-pattern>/users</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>AdminReviewsServlet</servlet-name>
    <servlet-class>com.easy2work.web.servlet.AdminReviewsServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>AdminReviewsServlet</servlet-name>
    <url-pattern>/reviews</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>AdminReportsServlet</servlet-name>
    <servlet-class>com.easy2work.web.servlet.AdminReportsServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>AdminReportsServlet</servlet-name>
    <url-pattern>/reports</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>AdminSettingsServlet</servlet-name>
    <servlet-class>com.easy2work.web.servlet.AdminSettingsServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>AdminSettingsServlet</servlet-name>
    <url-pattern>/settings</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>AdminServicesApiServlet</servlet-name>
    <servlet-class>com.easy2work.web.servlet.AdminServicesApiServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>AdminServicesApiServlet</servlet-name>
    <url-pattern>/api/admin/services</url-pattern>
  </servlet-mapping>

  <welcome-file-list>
    <welcome-file>index.jsp</welcome-file>
  </welcome-file-list>
</web-app>
